<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PoputkaKGAMT.TripRatingPage"
             Title="TripRatingPage"
             Shell.NavBarIsVisible="False"
             Background="White">
    <Grid RowDefinitions="Auto,Auto, 500" RowSpacing="5" Padding="0,5,0,0" >
        <Border Grid.Row="0"
                Background="#214484"
                HeightRequest="45"
                Margin="10,0,10,0"
                Stroke="#214484"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                VerticalOptions="Start"
                ZIndex="1">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto" ColumnSpacing="10">
                <Image Grid.Column="0" Source="backicon.png" 
                       HorizontalOptions="Center">
                </Image>

                <Label Grid.Column="1"
                       Text="Назад"
                       TextColor="White"
                       FontSize="20" 
                       FontAttributes="Bold"
                       Margin="-15,2,0,0"
                       Padding="0,5,15,0"/>
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding GoBackTripDetailsCommand}" />
            </Border.GestureRecognizers>
        </Border>

        <Label Grid.Row="1" FontAttributes="Italic" FontSize="15" TextColor="Gray" Text="Выберите попутчика для выставления оценки" Margin="15,0,15,0"></Label>
        <Grid Grid.Row="1" RowDefinitions="Auto, Auto" RowSpacing="5" IsVisible="{Binding IsReviewFormOpen}">
            <Border Grid.Row="0"
                    Background="White"
                    Margin="15,-10,15,0"
                    Stroke="#214484"
                    StrokeThickness="2"
                    VerticalOptions="Start">
                <!-- Данные -->
                <Grid RowDefinitions="Auto, Auto" RowSpacing="10" Padding="3" Margin="5,0,5,0">
                    <Grid Grid.Row="0" Padding="5,5,5,0" ColumnDefinitions="Auto, Auto, *, Auto" ColumnSpacing="10" RowDefinitions="Auto, Auto">
                        <Border Grid.Column="0" Grid.Row="0" HeightRequest="60"   
                                WidthRequest="60"
                                Stroke="#214484" 
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 70"
                                HorizontalOptions="Start"
                                ZIndex="1">
                            <Image Source="defoltavataricon.png" 
                                   Aspect="AspectFill"
                                   HeightRequest="55"     
                                   WidthRequest="55"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoCheckProfileCommand}" CommandParameter="{Binding}"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Image Source="profilecheckicon.png" Grid.Column="0" Grid.Row="0"   
                               HeightRequest="24"     
                               WidthRequest="24"
                               HorizontalOptions="Start"
                               VerticalOptions="End"
                               Margin="40,0,0,3"
                               ZIndex="2"/>

                        <VerticalStackLayout Grid.Column="0" Grid.Row="0" Padding="70,10,0,0" HorizontalOptions="Start"  >
                            <Label Text="{Binding SelectedUser.UserName}" FontSize="21" FontAttributes="Bold" TextColor="#214484" Padding="5,0,10,0" WidthRequest="250" LineBreakMode="TailTruncation"></Label>
                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="5" Padding="0,0,0,10">
                                <Image Grid.Column="0" Source="starrating.png" HeightRequest="27" WidthRequest="27"></Image>
                                <Label Grid.Column="1" Text="{Binding SelectedUser.UserRating}" FontSize="20" TextColor="Black" ></Label>
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1" Spacing="5">
                        <BoxView HeightRequest="2" 
                                 Color="#214484"
                                 HorizontalOptions="Fill"/>
                        <HorizontalStackLayout Padding="0,5,0,0" Spacing="12" HorizontalOptions="Center">
                            <Image x:Name="FirstStar" Source="darkbluestarholeicon.png" HeightRequest="35" WidthRequest="35" IsEnabled="True">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1"/>
                                </Image.GestureRecognizers>
                            </Image>
                            <Image x:Name="SecondStar" Source="darkbluestarholeicon.png" HeightRequest="35" WidthRequest="35" IsEnabled="True">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2"/>
                                </Image.GestureRecognizers>
                            </Image>
                            <Image x:Name="ThirdStar" Source="darkbluestarholeicon.png" HeightRequest="35" WidthRequest="35" IsEnabled="True">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3"/>
                                </Image.GestureRecognizers>
                            </Image>
                            <Image x:Name="FourStar" Source="darkbluestarholeicon.png" HeightRequest="35" WidthRequest="35" IsEnabled="True">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4"/>
                                </Image.GestureRecognizers>
                            </Image>
                            <Image x:Name="FiveStar" Source="darkbluestarholeicon.png" HeightRequest="35" WidthRequest="35" IsEnabled="True">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="2" 
                                 Color="#214484"
                                 HorizontalOptions="Fill"
                                 Margin="0,5,0,0"/>
                        <!-- Описание -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5" Padding="3,3,0,0">
                            <Image Grid.Column="0" 
                                   Source="reviewicon.png"
                                   HeightRequest="25" WidthRequest="25"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" 
                                   Text="Оставить отзыв"
                                   FontSize="20"
                                   TextColor="#214484"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Label Text="Не обязательно" FontSize="15" TextColor="Gray" VerticalOptions="Start" Margin="4,-3,0,0"></Label>
                        <Editor FontSize="16"
                                BackgroundColor="White"
                                MaxLength="1000"
                                AutoSize="TextChanges"
                                HorizontalOptions="Fill"
                                Margin="-2,0,0,5"
                                Text="{Binding Review}"/>

                    </VerticalStackLayout>
                </Grid>
            </Border>
            <Border Grid.Row="1" BackgroundColor="#214484"
                    Stroke="#214484"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 0,0,10,10"
                    Margin="15,-10,15,0"
                    VerticalOptions="End"
                    HeightRequest="40">
                <Label Text="Подтвердить"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="17"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" 
                        VerticalOptions="Center"
                        Padding="2"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseReviewFormAndSendDataCommand}" />
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <!-- Список -->
        <ScrollView Grid.Row="2"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    Padding="10,0,10,0" 
                    Margin="5,0,5,0">
            <CollectionView ItemsSource="{Binding UsersForEstimate}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid RowSpacing="0" Padding="0,0,0,10" RowDefinitions="Auto, Auto, Auto">
                            <Border Grid.Row="0" Background="White"
                                    Stroke="#214484"
                                    StrokeThickness="2" 
                                    StrokeShape="RoundRectangle 10,10,10,10">
                                <Grid Padding="15,5,15,12" ColumnDefinitions="Auto, Auto, *, Auto" ColumnSpacing="10" RowDefinitions="Auto, Auto" RowSpacing="10">
                                    <Border Grid.Column="0" Grid.Row="0" HeightRequest="60"   
                                            WidthRequest="60"
                                            Stroke="#214484" 
                                            StrokeThickness="2"
                                            StrokeShape="RoundRectangle 70"
                                            HorizontalOptions="Start"
                                            ZIndex="98">
                                        <Image Source="defoltavataricon.png" 
                                               Aspect="AspectFill"
                                               HeightRequest="55"     
                                               WidthRequest="55"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoCheckProfileCommand}" CommandParameter="{Binding}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Image Source="profilecheckicon.png" Grid.Column="0" Grid.Row="0"   
                                           HeightRequest="25"     
                                           WidthRequest="25"
                                           HorizontalOptions="Start"
                                           VerticalOptions="End"
                                           Margin="37,0,0,0"
                                           ZIndex="99"/>

                                    <VerticalStackLayout 
                                    IsEnabled="{Binding CanReview}" Grid.Column="0" Grid.Row="0" Padding="67,10,10,0" HorizontalOptions="Start">
                                        <Label Text="{Binding UserName}" FontSize="22" FontAttributes="Bold" TextColor="#214484" Padding="5,0,20,0" WidthRequest="225" LineBreakMode="TailTruncation"></Label>
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="5">
                                            <Image Grid.Column="0" Source="starrating.png" HeightRequest="25" WidthRequest="25"></Image>
                                            <Label Grid.Column="1" Text="{Binding UserRating}" FontSize="21" TextColor="Black" ></Label>
                                        </Grid>
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenReviewFormCommand}" CommandParameter="{Binding}"/>
                                        </VerticalStackLayout.GestureRecognizers>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" IsVisible="{Binding UserHaveReview}" 
                                     BackgroundColor="White"
                                     Stroke="#214484"
                                     StrokeThickness="2"
                                     StrokeShape="RoundRectangle 0,0,10,10"
                                     Margin="0,-15,0,0"
                                     HorizontalOptions="Fill"
                                     VerticalOptions="Center">
                                <Grid RowDefinitions="Auto, Auto, Auto">
                                    <Label Grid.Row="0" Text="{Binding EstimateTitle}" 
                                           BackgroundColor="Transparent"
                                           TextColor="#214484"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Start"                        
                                           Padding="10,3,0,0"/>
                                    
                                    <Label Grid.Row="1"
                                           IsVisible="{Binding IsUserHaveReviewForShow}"
                                           Text="{Binding Review}" 
                                           BackgroundColor="Transparent"
                                           TextColor="#4167AB"
                                           FontSize="16"
                                           FontAttributes="Italic"
                                           HorizontalOptions="Start" 
                                           WidthRequest="280" 
                                           LineBreakMode="TailTruncation"
                                           Padding="10,-3,0,0"/>
                                    
                                    <Label Grid.Row="2"
                                           Text="{Binding Created}" 
                                           BackgroundColor="Transparent"
                                           TextColor="#4167AB"
                                           FontSize="16"
                                           HorizontalOptions="Start"                        
                                           Padding="10,5,0,3"/>
                                </Grid>
                            </Border>
                            
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </Grid>
</ContentPage>